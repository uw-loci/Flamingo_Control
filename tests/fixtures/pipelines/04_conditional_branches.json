{
  "format_version": "1.0",
  "name": "04 Conditional Branches",
  "nodes": [
    {
      "id": "n-threshold",
      "node_type": "THRESHOLD",
      "name": "Threshold",
      "inputs": [
        {"id": "n-threshold:in:volume", "name": "volume", "port_type": "VOLUME", "direction": "INPUT", "required": false}
      ],
      "outputs": [
        {"id": "n-threshold:out:objects", "name": "objects", "port_type": "OBJECT_LIST", "direction": "OUTPUT", "required": false},
        {"id": "n-threshold:out:mask", "name": "mask", "port_type": "VOLUME", "direction": "OUTPUT", "required": false},
        {"id": "n-threshold:out:count", "name": "count", "port_type": "SCALAR", "direction": "OUTPUT", "required": false}
      ],
      "config": {
        "channel_thresholds": {"0": 100},
        "enabled_channels": [0],
        "default_threshold": 100
      },
      "x": 50.0, "y": 100.0
    },
    {
      "id": "n-conditional",
      "node_type": "CONDITIONAL",
      "name": "Any Objects?",
      "inputs": [
        {"id": "n-cond:in:value", "name": "value", "port_type": "ANY", "direction": "INPUT", "required": true},
        {"id": "n-cond:in:threshold", "name": "threshold", "port_type": "SCALAR", "direction": "INPUT", "required": false}
      ],
      "outputs": [
        {"id": "n-cond:out:true", "name": "true_branch", "port_type": "TRIGGER", "direction": "OUTPUT", "required": false},
        {"id": "n-cond:out:false", "name": "false_branch", "port_type": "TRIGGER", "direction": "OUTPUT", "required": false},
        {"id": "n-cond:out:passthrough", "name": "pass_through", "port_type": "ANY", "direction": "OUTPUT", "required": false}
      ],
      "config": {
        "comparison_op": ">",
        "threshold_value": 0
      },
      "x": 300.0, "y": 100.0
    },
    {
      "id": "n-workflow",
      "node_type": "WORKFLOW",
      "name": "Reacquire",
      "inputs": [
        {"id": "n-wf:in:trigger", "name": "trigger", "port_type": "TRIGGER", "direction": "INPUT", "required": false},
        {"id": "n-wf:in:position", "name": "position", "port_type": "POSITION", "direction": "INPUT", "required": false},
        {"id": "n-wf:in:z_range", "name": "z_range", "port_type": "OBJECT", "direction": "INPUT", "required": false}
      ],
      "outputs": [
        {"id": "n-wf:out:volume", "name": "volume", "port_type": "VOLUME", "direction": "OUTPUT", "required": false},
        {"id": "n-wf:out:file_path", "name": "file_path", "port_type": "FILE_PATH", "direction": "OUTPUT", "required": false},
        {"id": "n-wf:out:completed", "name": "completed", "port_type": "TRIGGER", "direction": "OUTPUT", "required": false}
      ],
      "config": {"template_file": "", "use_input_position": false, "auto_z_range": false, "auto_tiling": false, "buffer_percent": 25.0},
      "x": 600.0, "y": 50.0
    },
    {
      "id": "n-extcmd",
      "node_type": "EXTERNAL_COMMAND",
      "name": "Skip Action",
      "inputs": [
        {"id": "n-ext:in:input_data", "name": "input_data", "port_type": "ANY", "direction": "INPUT", "required": false},
        {"id": "n-ext:in:trigger", "name": "trigger", "port_type": "TRIGGER", "direction": "INPUT", "required": false}
      ],
      "outputs": [
        {"id": "n-ext:out:output_data", "name": "output_data", "port_type": "ANY", "direction": "OUTPUT", "required": false},
        {"id": "n-ext:out:file_path", "name": "file_path", "port_type": "FILE_PATH", "direction": "OUTPUT", "required": false},
        {"id": "n-ext:out:completed", "name": "completed", "port_type": "TRIGGER", "direction": "OUTPUT", "required": false}
      ],
      "config": {
        "command_template": "true",
        "input_format": "json",
        "output_format": "json",
        "timeout_seconds": 10
      },
      "x": 600.0, "y": 200.0
    }
  ],
  "connections": [
    {"id": "c-thresh-count-to-cond-value", "source_node_id": "n-threshold", "source_port_id": "n-threshold:out:count", "target_node_id": "n-conditional", "target_port_id": "n-cond:in:value"},
    {"id": "c-cond-true-to-wf-trigger", "source_node_id": "n-conditional", "source_port_id": "n-cond:out:true", "target_node_id": "n-workflow", "target_port_id": "n-wf:in:trigger"},
    {"id": "c-cond-false-to-ext-trigger", "source_node_id": "n-conditional", "source_port_id": "n-cond:out:false", "target_node_id": "n-extcmd", "target_port_id": "n-ext:in:trigger"}
  ]
}
